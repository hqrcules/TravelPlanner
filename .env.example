# Application
APP_NAME=Travel Planner
APP_ENV=development
LOG_LEVEL=INFO

# Database (use postgresql+asyncpg for Postgres or sqlite+aiosqlite for fallback)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/travel_planner
# DATABASE_URL=sqlite+aiosqlite:///./travel_planner.db

# Redis cache (leave empty to use in-memory fallback)
REDIS_URL=redis://redis:6379/0

# Art Institute of Chicago API
ARTIC_BASE_URL=https://api.artic.edu/api/v1
ARTIC_TIMEOUT_SECONDS=5
ARTIC_CACHE_TTL_SECONDS=3600

# Basic Auth credentials
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# CORS (comma-separated)
CORS_ORIGINS=*
